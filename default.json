{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":semanticCommits",
    ":semanticCommitTypeAll(fix)",
    ":prHourlyLimitNone",
    ":prConcurrentLimitNone",
    "github>slauger/renovate-config:regex-comments"
  ],
  "labels": ["renovate"],
  "separateMinorPatch": true,
  "git-submodules": {
    "enabled": true
  },
  "bundler": {
    "enabled": true
  },
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "dockerfile": {
    "fileMatch": [
      "(^|/)Dockerfile$",
      "(^|/)Dockerfile\\.[^/]*$",
      "(^|/)\\.*Dockerfile$"
    ]
  }
}
